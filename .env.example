# --- Banco de dados próprio do sistema (SQL Server) ---
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=analise_credito
DB_USER=sa
DB_PASSWORD=changeme
DB_DRIVER=ODBC Driver 18 for SQL Server

# --- SAP Business One Service Layer ---
SAP_SERVICE_LAYER_URL=https://sap-server:50000/b1s/v1
SAP_COMPANY_DB=SBO_PRODUCAO
SAP_USERNAME=changeme
SAP_PASSWORD=changeme
SAP_VERIFY_SSL=true

# --- Serasa Experian API (Concentre/CredCheck) ---
SERASA_API_URL=https://api.serasaexperian.com.br
SERASA_CLIENT_ID=changeme
SERASA_CLIENT_SECRET=changeme
# TTL em horas: não reconsultar o mesmo cliente antes desse prazo
SERASA_QUERY_CACHE_TTL_HOURS=24

# --- Redis (Celery broker/backend) ---
REDIS_URL=redis://redis:6379/0

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=changeme
