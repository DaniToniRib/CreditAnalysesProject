# --- Banco de dados próprio do sistema (SQL Server) ---
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=analise_credito
DB_USER=sa
DB_PASSWORD=changeme
DB_DRIVER=ODBC Driver 18 for SQL Server
# true = aceita certificado autoassinado do SQL Server (comum em instalações
# on-prem). Trocar para false assim que houver um certificado válido
# configurado no servidor — caso contrário a conexão fica exposta a MITM.
DB_TRUST_SERVER_CERTIFICATE=true

# --- SAP Business One Service Layer ---
SAP_SERVICE_LAYER_URL=https://sap-server:50000/b1s/v1
SAP_COMPANY_DB=SBO_PRODUCAO
SAP_USERNAME=changeme
SAP_PASSWORD=changeme
SAP_VERIFY_SSL=true

# --- Serasa Experian API (Concentre/CredCheck) ---
SERASA_API_URL=https://api.serasaexperian.com.br
SERASA_CLIENT_ID=changeme
SERASA_CLIENT_SECRET=changeme
# TTL em horas: não reconsultar o mesmo cliente antes desse prazo
SERASA_QUERY_CACHE_TTL_HOURS=24

# --- Redis (Celery broker/backend) ---
REDIS_URL=redis://redis:6379/0

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=changeme
# Chave que integrações (SAP, sistemas internos) devem enviar no header
# `X-API-Key` para chamar a API. Gerar com: openssl rand -hex 32
API_KEY=changeme
# Limite de requisições por IP por minuto (proteção contra força bruta/abuso)
RATE_LIMIT_PER_MINUTE=120
